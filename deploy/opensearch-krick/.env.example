# Site-specific settings for the opensearch-krick stack.
# Copy to .env (gitignored) and edit. NO hostnames/paths in git.

OS_VERSION=3.6.0
OS_CLUSTER_NAME=pipestream-krick
OS_NODE_NAME=opensearch-krick

# Heap: <= 32g; default 24g on a 64 GB box leaves ~40 GB native for
# k-NN graphs (circuit breaker below) + Lucene page cache.
OS_HEAP=24g
OS_KNN_CB=60%

OS_REST_PORT=9200
OS_PERF_PORT=9600

# Index defaults applied by the init-templates sidecar.
OS_DEFAULT_SHARDS=6
OS_DEFAULT_REPLICAS=0
OS_DEFAULT_REFRESH=30s

# NVMe data path (then switch the volume to the bind-mount block in the
# compose file): e.g. /mnt/nvme/opensearch/data
#OS_DATA_DIR=
